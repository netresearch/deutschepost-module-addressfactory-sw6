parameters:
    level: 7
    tmpDir: var/cache/phpstan
    inferPrivatePropertyTypeFromConstructor: true
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
    paths:
        -   src
        -   test
    excludePaths:
        -   test/TestBootstrap.php
    symfony:
        constantHassers: false
